# ============================================================
# .env.example — テンプレート（Gitにコミットする・秘密情報は書かない）
# 使い方: cp .env.example .env.local して値を埋める
# ============================================================

# Admin password (required for /admin login)
ADMIN_PASSWORD=change-me

# --- Vercel KV / Upstash Redis ---
# Vercel で Storage を接続すると、ストア名に応じた変数名が自動発行されます。
# 例: quickask というストア名 → quickask_KV_REST_API_URL / quickask_KV_REST_API_TOKEN
#
# どちらの名前でもコードが読み取れます（リネーム不要）:
#   KV_REST_API_URL / KV_REST_API_TOKEN          ← 標準名
#   quickask_KV_REST_API_URL / quickask_KV_REST_API_TOKEN  ← Upstash 発行名

# ローカル開発用（Upstash ダッシュボードの値をコピー）
# quickask_KV_REST_API_URL=https://xxxx.upstash.io
# quickask_KV_REST_API_TOKEN=AXxxxx
